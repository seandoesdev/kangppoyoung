# DB 자격증명 (docker-compose 가 backend·mysql 에 주입)
DB_USERNAME=policyfund
DB_PASSWORD=change-me
DB_ROOT_PASSWORD=change-me-root

# OpenAI: 기본 검색이 openai(임베딩+gpt-4o 답변 합성)이므로 실제 sk-... 키가 필요하다.
# 아래 sk-noop 그대로 두면 컨텍스트는 뜨지만 검색·부팅 적재가 실패한다(빈 값은 부팅 자체가 실패).
# 따라서 실사용 시 반드시 실제 키로 교체할 것.
OPENAI_API_KEY=sk-noop

# 키 없이 오프라인으로 돌리려면 아래 두 줄의 주석을 풀어 provider 를 전환한다(이때 OPENAI_API_KEY 는 sk-noop 유지).
# 단 오프라인 해시 임베딩은 의미 검색 품질이 낮고, 오프라인 합성기는 답변을 생성하지 않고 근거만 나열한다.
#SEARCH_EMBEDDING_PROVIDER=hash
#SEARCH_SYNTH_PROVIDER=offline

# nginx 호스트 포트(기본 80). 호스트 80이 사용 중이면 변경.
NGINX_PORT=80
