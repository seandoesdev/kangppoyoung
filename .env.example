# DB 자격증명 (docker-compose 가 backend·mysql 에 주입)
DB_USERNAME=policyfund
DB_PASSWORD=change-me
DB_ROOT_PASSWORD=change-me-root

# OpenAI: 키가 없으면 반드시 오프라인 센티넬 sk-noop 을 둔다.
# 빈 값으로 두면 Spring AI 챗 모델 빈이 부팅 단계에서 실패해 backend 가 뜨지 않는다
# (검색 자체는 오프라인 동작하지만 Vision/분류 빈이 무조건 챗 모델을 끌어옴).
# OpenAI 기능(Vision OCR·질문분류·OpenAI 합성/임베딩)을 쓰려면 실제 sk-... 키로 교체.
OPENAI_API_KEY=sk-noop

# nginx 호스트 포트(기본 80). 호스트 80이 사용 중이면 변경.
NGINX_PORT=80
